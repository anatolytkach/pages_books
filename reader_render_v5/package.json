{
  "name": "pages_books-protected-reader-tooling",
  "private": true,
  "version": "0.0.1",
  "description": "Local audit and font-analysis tooling for the protected reader project.",
  "scripts": {
    "protected:audit": "node tools/protected-fonts/protected-audit.js",
    "protected:build": "node tools/protected-ingestion/build-protected-book.js",
    "protected:build:debug": "node tools/protected-ingestion/build-protected-book.js --debug-artifact",
    "protected:fonts:scan": "node tools/protected-fonts/scan-corpus.js",
    "protected:fonts:plan": "node tools/protected-fonts/build-font-plan.js",
    "protected:validate": "node tools/protected-ingestion/validate-protected-book.js",
    "ui:smoke": "node tools/internal/reader-new-ui-smoke.js",
    "ui:smoke:canonical-url": "node -e \"console.log(require('./tools/internal/reader-new-test-fixture').DEFAULT_PROTECTED_UI_SMOKE_URL)\"",
    "ui:smoke:desktop": "node tools/internal/reader-new-ui-smoke.js --scenario=desktop-shell",
    "ui:smoke:settings": "node tools/internal/reader-new-ui-smoke.js --scenario=desktop-settings",
    "ui:smoke:library": "node tools/internal/reader-new-ui-smoke.js --scenario=desktop-library",
    "ui:smoke:search": "node tools/internal/reader-new-ui-smoke.js --scenario=desktop-search",
    "ui:smoke:mobile": "node tools/internal/reader-new-ui-smoke.js --scenario=mobile-shell",
    "ui:smoke:mobile-settings": "node tools/internal/reader-new-ui-smoke.js --scenario=mobile-settings"
  },
  "dependencies": {
    "harfbuzzjs": "^0.4.13",
    "opentype.js": "^1.3.4",
    "playwright-core": "^1.59.1"
  }
}
